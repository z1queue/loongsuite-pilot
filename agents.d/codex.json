{
  "id": "codex",
  "displayName": "Codex",
  "deployMode": "hook",
  "detection": {
    "paths": ["~/.codex"],
    "commands": []
  },
  "hook": {
    "settingsPath": "~/.codex/hooks.json",
    "events": ["Stop"],
    "retiredEvents": ["SessionStart", "UserPromptSubmit", "PreToolUse", "PostToolUse", "PostToolUseFailure"],
    "hookCommand": "$PILOT_DATA/hooks/codex-loongsuite-pilot-hook.sh",
    "format": "nested",
    "matcher": "*",
    "eventSubcommand": "kebab-case",
    "replaceHookCommands": [
      "otel-codex-hook",
      ".cache/opentelemetry.instrumentation.codex"
    ],
    "trustToml": {
      "configPath": "~/.codex/config.toml",
      "trustAlgo": "v1",
      "marker": "otel-codex-hook"
    }
  },
  "input": {
    "type": "session-file-polling"
  }
}
