# L2 E2E (advanced scenarios: reboot, multi-account, auto-upgrade,
# version-matrix, SSH remote). Most users do NOT need this file —
# see .env.e2e.example for L1 docker quick check.
#
# Copy to .env.e2e if you need to run an L2 scenario:
#   cp .env.e2e.l2.example .env.e2e
#   E2E_SCENARIO=reboot-autostart npm run test:e2e:l2
#   # or:  npm run test:e2e:l2:remote

# ============================================================
# Common Settings
# ============================================================

E2E_SCENARIO=install-smoke
E2E_USER_ID=your-employee-id
# E2E_USER_IDS=id1,id2,id3          # for multi-account scenario
E2E_PROFILE=linux-8u

# ============================================================
# Agent API Keys (Dashscope/百炼)
# ============================================================

# Codex CLI (uses Dashscope OpenAI-compatible endpoint)
E2E_CODEX_OPENAI_API_KEY=sk-your-dashscope-key

# Claude Code (via 百炼 proxy)
E2E_ANTHROPIC_API_KEY=sk-your-dashscope-key
E2E_CLAUDE_BAILIAN=1
E2E_CLAUDE_BAILIAN_API_KEY=sk-your-dashscope-key

# Claude proxy config
E2E_WRITE_REMOTE_CLAUDE_PROXY_CONFIG=1
E2E_CLAUDE_PROXY_API_KEY=sk-your-dashscope-key

# Cursor Agent CLI
E2E_CURSOR_API_KEY=sk-your-dashscope-key

# Qoder CLI
E2E_QODER_PERSONAL_ACCESS_TOKEN=pt-your-qoder-pat

# ============================================================
# Agent Probe Settings
# ============================================================

E2E_USE_MATRIX_PROBE=1
E2E_WRITE_REMOTE_CODEX_CONFIG=1
E2E_WRITE_REMOTE_CLAUDE_ONBOARDING_SKIP=1
E2E_JSONL_VALIDATE=1
# E2E_PROBE_SKIP_AGENTS=cursor           # skip these agents from probe (comma-separated binary names)
# E2E_REQUIRED_JSONL_AGENTS=claude-code,codex,qoder  # require these agents to produce JSONL (default: claude-code,codex,qoder)

# ============================================================
# SLS (Alibaba Cloud Log Service)
# ============================================================

E2E_SLS_PROJECT=your-sls-project
E2E_SLS_ENDPOINT=cn-hongkong.log.aliyuncs.com
E2E_SLS_LOGSTORE=your-logstore
# E2E_SLS_ACCESS_KEY_ID=your-ak       # optional
# E2E_SLS_ACCESS_KEY_SECRET=your-sk    # optional

# ============================================================
# Docker Mode Settings
# ============================================================

E2E_DOCKER_KEEP_ALIVE=0
# E2E_DOCKER_EXIT_ON_FAILURE=1        # for CI: exit immediately on failure

# ============================================================
# SSH Mode Settings (only for ./scripts/e2e/run-e2e.sh ssh)
# ============================================================

# E2E_SSH_TARGET=your-user@remote-host
# E2E_SSH_PASSWORD_AUTH=1              # if using password auth

# ============================================================
# Version Matrix Settings (E2E_SCENARIO=version-matrix)
# ============================================================

# E2E_AGENT_VERSIONS_N=3
# E2E_AGENT_VERSIONS_FILTER=codex,claude
E2E_LOCAL_BUILD=1
